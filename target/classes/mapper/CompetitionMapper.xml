<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.quan.project.mapper.CompetitionMapper">

    <!-- 结果映射 -->
    <resultMap id="CompetitionResultMap" type="com.quan.project.entity.Competition">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="competitionDate" column="competition_date"/>
        <result property="status" column="status"/>
    </resultMap>

    <!-- CompetitionVO结果映射（包含报名人数） -->
    <resultMap id="CompetitionVOResultMap" type="com.quan.project.vo.CompetitionVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="competitionDate" column="competition_date"/>
        <result property="status" column="status"/>
        <result property="participantCount" column="participant_count"/>
    </resultMap>

    <!-- 插入比赛 -->
    <insert id="insert" parameterType="com.quan.project.entity.Competition" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO competitions (name, competition_date, status)
        VALUES (#{name}, #{competitionDate}, #{status})
    </insert>

    <!-- 根据ID删除比赛 -->
    <delete id="deleteById">
        DELETE FROM competitions WHERE id = #{id}
    </delete>

    <!-- 更新比赛信息 -->
    <update id="update" parameterType="com.quan.project.entity.Competition">
        UPDATE competitions SET
        <if test="name != null and name != ''">
            name = #{name},
        </if>
        <if test="competitionDate != null">
            competition_date = #{competitionDate},
        </if>
        <if test="status != null">
            status = #{status},
        </if>
        id = #{id}
        WHERE id = #{id}
    </update>

    <!-- 更新比赛状态 -->
    <update id="updateStatus">
        UPDATE competitions SET status = #{status} WHERE id = #{id}
    </update>

    <!-- 根据ID查询比赛 -->
    <select id="selectById" resultMap="CompetitionResultMap">
        SELECT * FROM competitions WHERE id = #{id}
    </select>

    <!-- 分页查询比赛（支持动态条件，包含报名人数） -->
    <select id="selectPageByConditions" resultMap="CompetitionVOResultMap">
        SELECT 
            c.id,
            c.name,
            c.competition_date,
            c.status,
            COALESCE(p.participant_count, 0) AS participant_count
        FROM competitions c
        LEFT JOIN (
            SELECT 
                competition_id,
                COUNT(*) AS participant_count
            FROM competition_participants
            GROUP BY competition_id
        ) p ON c.id = p.competition_id
        <where>
            <if test="request != null and request.params != null">
                <if test="request.params.name != null and request.params.name != '' and request.params.name.trim() != ''">
                    AND c.name LIKE CONCAT('%', #{request.params.name}, '%')
                </if>
                <if test="request.params.status != null">
                    AND c.status = #{request.params.status}
                </if>
                <if test="request.params.startDate != null">
                    AND c.competition_date >= #{request.params.startDate}
                </if>
                <if test="request.params.endDate != null">
                    AND c.competition_date &lt;= #{request.params.endDate}
                </if>
            </if>
        </where>
        ORDER BY c.competition_date DESC
    </select>

    <!-- 查询所有比赛 -->
    <select id="selectAll" resultMap="CompetitionResultMap">
        SELECT * FROM competitions ORDER BY competition_date DESC
    </select>

    <!-- 查询当前可报名的比赛 -->
    <select id="selectAvailableCompetitions" resultMap="CompetitionResultMap">
        SELECT * FROM competitions WHERE status = 0 ORDER BY competition_date ASC
    </select>

    <!-- 查询进行中的比赛 -->
    <select id="selectInProgressCompetitions" resultMap="CompetitionResultMap">
        SELECT * FROM competitions WHERE status = 1 ORDER BY competition_date ASC
    </select>

</mapper>
